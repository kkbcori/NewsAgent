# ── Required ──────────────────────────────────────────────────────────────────
# Groq API — FREE, no credit card needed
# Sign up at: https://console.groq.com
# Free tier: 14,400 requests/day, 30 req/min — more than enough
GROQ_API_KEY=gsk_...

# ── Optional ──────────────────────────────────────────────────────────────────
# YouTube Data API v3 — for trending India videos
# Free: 10,000 units/day. Get at: https://console.cloud.google.com
# Without this, YouTube channel RSS (no key needed) still works fine.
YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY
