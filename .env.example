# Required — get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional — enables YouTube trending India (top 15 videos)
# Get free key: https://console.cloud.google.com → Enable YouTube Data API v3
# Free quota: 10,000 units/day. Trending fetch = 1 unit per run.
# Without this key, YouTube channel RSS (no quota) is still used.
YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY
